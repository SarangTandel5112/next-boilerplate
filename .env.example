# =============================================================================
# ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in your values
# =============================================================================

# Application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# API Configuration
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_DATA_SOURCE=auto

# Authentication
AUTH_SESSION_SECRET=
AUTH_ADMIN_EMAIL=
# Must be a bcrypt hash (example generated with bcryptjs)
AUTH_ADMIN_PASSWORD=
AUTH_SESSION_PREVIOUS_SECRETS=
AUTH_LOGIN_RATE_LIMIT_MAX=10
AUTH_LOGIN_RATE_LIMIT_WINDOW_MS=900000
REDIS_URL=

# Analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Error Monitoring
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DISABLED=

# Logging
NEXT_PUBLIC_LOGGING_LEVEL=info
LOG_LEVEL=info
